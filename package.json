{
  "name": "servicecall",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "dev:emulator": "cross-env VITE_USE_EMULATORS=true vite",
    "em:start": "firebase emulators:start --only auth,firestore --project demo-servicecall",
    "em:exec": "firebase emulators:exec --project demo-servicecall --only auth,firestore \"node scripts/run-dev-emulator.cjs\"",
    "cy:run:app": "cypress run --spec cypress/e2e/App.cy.js",
    "em:cy:open": "start-server-and-test em:exec http://localhost:5173 cy:open",
    "em:cy:run": "start-server-and-test em:exec http://localhost:5173 cy:run:app"
  },
  "dependencies": {
    "babel-plugin-react-compiler": "^1.0.0",
    "firebase": "^11.10.0",
    "leaflet": "^1.9.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-leaflet": "^5.0.0",
    "react-router-dom": "^7.4.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@tailwindcss/vite": "^4.1.3",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/leaflet": "^1.9.21",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^10.1.0",
    "cypress": "^15.17.0",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "firebase-tools": "^15.19.1",
    "globals": "^15.15.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.5.3",
    "start-server-and-test": "^3.0.9",
    "tailwindcss": "^4.1.3",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.26.1",
    "vite": "^6.2.2",
    "vitest": "^3.1.1"
  }
}
